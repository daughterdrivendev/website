<div reversed class="postlist">
{%- for post in postslist | reverse %}
	<article class="postlist-item{% if post.url == url %} postlist-item-active{% endif %}">
		<h2>
			<a href="{{ post.url }}" class="postlist-link">{% if post.data.title %}{{ post.data.title }}{% else %}<code>{{ post.url }}</code>{% endif %}</a>
		</h2>
		<section class="postlist-metadata">
			<time class="postlist-date" datetime="{{ post.date | htmlDateString }}">
				{{ post.date | readableDate("dd LLLL yyyy") }}
				<!-- add tags here -->
			</time>
			<small class="postlist-author">• {{post.data.author}}</small>
		</section>
		<p>{{ post.templateContent | htmlExcerpt | safe }}</p>
	</article>
{%- endfor %}
</div>
