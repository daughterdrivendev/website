---
interface Props {
  currentPath: string;
  navAlign?: 'end' | 'center';
}

const { currentPath, navAlign = 'end' } = Astro.props;

const navItems = [
  { href: '/', label: 'home', id: 'home' },
  { href: '/blog/', label: 'blog', id: 'blog' },
  { href: '/about/', label: 'about', id: 'about' },
  { href: '/newsletter/', label: 'newsletter', id: 'newsletter' },
];

function isActive(href: string, currentPath: string): boolean {
  if (href === '/') {
    return currentPath === '/' || currentPath === '';
  }
  return currentPath.startsWith(href.replace(/\/$/, ''));
}
---

<!-- Desktop Navigation -->
<nav class:list={['hidden lg:block bookmark-nav', navAlign === 'end' && 'mr-8']}>
  <ul class:list={['flex items-center space-x-6', navAlign === 'end' ? 'justify-end' : 'justify-center']}>
    {navItems.map((item) => (
      <li>
        <a
          href={item.href}
          class:list={[
            'bookmark-link block text-sm transition-all',
            isActive(item.href, currentPath)
              ? 'bookmark-active'
              : 'bookmark-inactive'
          ]}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<!-- Mobile Navigation -->
<nav class="lg:hidden mobile-header">
  <div class="flex items-center justify-between px-4 py-3">
    <a href="/" class="text-lg font-serif font-light">
      daughter<span class="italic">driven</span>.dev
    </a>
    <button
      id="mobile-menu-button"
      class="p-2 text-white/80 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/20 rounded"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden border-t border-white/10">
    <ul class="py-2">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'block px-4 py-3 text-sm transition-colors',
              isActive(item.href, currentPath)
                ? 'text-white bg-white/10'
                : 'text-white/80 hover:text-white hover:bg-white/5'
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  function toggleMenu() {
    const isExpanded = button?.getAttribute('aria-expanded') === 'true';
    button?.setAttribute('aria-expanded', String(!isExpanded));
    button?.setAttribute('aria-label', isExpanded ? 'Open menu' : 'Close menu');
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');

    // Focus trap: when menu opens, focus first link
    if (!isExpanded && menu) {
      const firstLink = menu.querySelector('a');
      firstLink?.focus();
    }
  }

  button?.addEventListener('click', toggleMenu);

  // Close menu on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && button?.getAttribute('aria-expanded') === 'true') {
      toggleMenu();
      button?.focus();
    }
  });
</script>
