---
import BookLayout from '../../layouts/BookLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BookLayout
  title="Blog - daughterdriven.dev"
  description="Thoughts on engineering, parenthood, and finding balance between the two."
>
  <div class="px-4 py-8 sm:p-8 lg:p-12">
    <div class="max-w-lg lg:max-w-2xl mx-auto lg:mx-0 lg:ml-8">
      <header class="mb-8 lg:mb-12">
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-serif font-light tracking-tight lg:text-sidebar">Recently on the blog</h1>
        <p class="mt-3 lg:mt-4 text-gray-700 lg:text-lg">Thoughts on engineering, parenthood, and finding balance between the two.</p>
      </header>

      {sortedPosts.length === 0 ? (
        <p class="text-gray-600">No posts yet. Check back soon!</p>
      ) : (
        <ul class="space-y-6 lg:space-y-10">
          {sortedPosts.map((post) => (
            <li class="lg:border-b lg:border-gray-200 lg:pb-8 lg:last:border-0">
              <a href={`/blog/${post.slug}/`} class="block group">
                <article>
                  <time datetime={post.data.date.toISOString()} class="text-xs lg:text-sm text-gray-600">
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                  <h2 class="text-lg lg:text-2xl font-serif mt-1 group-hover:text-sidebar transition-colors">{post.data.title}</h2>
                  <p class="mt-1 lg:mt-2 text-sm lg:text-base text-gray-700 lg:leading-relaxed">{post.data.description}</p>
                </article>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</BookLayout>
