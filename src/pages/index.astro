---
import BookLayout from '../layouts/BookLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BookLayout
  title="daughterdriven.dev"
  description="A book for engineers navigating the beautiful chaos of parenthood. Real stories, practical insights, and honest conversations."
  variant="landing"
>
  <!-- Mobile Content (default slot) -->
  <div class="lg:hidden px-4 py-8 sm:p-8">
    <div class="max-w-lg mx-auto space-y-6 text-center">
      <!-- Illustration -->
      <div class="py-4">
        <img
          src="/o0ygAv5gTU36S0LUYTtDS.webp"
          alt="Parent and child working together at a computer"
          class="w-full max-w-[180px] h-auto mx-auto"
        />
      </div>

      <!-- Headline -->
      <h2 class="text-2xl sm:text-3xl font-serif leading-tight">
        Engineer <span class="italic">and</span> a parent?<br />
        Can be tough.<br />
        But you are not alone.
      </h2>

      <!-- Description -->
      <p class="text-gray-700 leading-relaxed">
        A book for engineers navigating the beautiful chaos of parenthood.
        Real stories, practical insights, and honest conversations about thriving in both worlds.
      </p>

      <p class="text-gray-700 leading-relaxed">
        Interested in updates on the book? Join the newsletter to stay informed.
      </p>

      <!-- Newsletter Form -->
      <div id="newsletter" class="pt-2">
        <NewsletterForm variant="light" layout="stacked" />
      </div>
    </div>
  </div>

  <!-- Desktop: Left sidebar content (text + form) -->
  <div slot="sidebar" class="space-y-8 max-w-md mx-auto">
    <!-- Brand Name -->
    <h1 class="text-4xl font-serif font-light tracking-tight">
      daughter<span class="italic">driven</span>.dev
    </h1>

    <!-- Headline -->
    <h2 class="text-4xl font-serif leading-tight">
      Engineer <span class="italic">and</span> a parent?<br />
      Can be tough.<br />
      But you are not alone.
    </h2>

    <!-- Description -->
    <div class="space-y-4 text-white/80 leading-relaxed">
      <p>
        A book for engineers navigating the beautiful chaos of parenthood.
        Real stories, practical insights, and honest conversations about thriving in both worlds.
      </p>
      <p>
        Interested in updates on the book? Join the newsletter to stay informed.
      </p>
    </div>

    <!-- Newsletter Form -->
    <div id="newsletter-desktop" class="pt-2">
      <NewsletterForm variant="dark" layout="inline" />
    </div>
  </div>

  <!-- Desktop: Right main content (illustration) -->
  <div slot="main" class="p-12">
    <img
      src="/o0ygAv5gTU36S0LUYTtDS.webp"
      alt="Parent and child working together at a computer"
      class="w-full max-w-lg h-auto"
    />
  </div>
</BookLayout>
