---
import BookLayout from '../layouts/BookLayout.astro';
---

<BookLayout
  title="Imprint - daughterdriven.dev"
  description="Legal disclosure and contact information for daughterdriven.dev"
  noindex={true}
>
  <!-- Mobile Content -->
  <div class="lg:hidden px-4 py-8 sm:p-8">
    <div class="max-w-lg mx-auto">
      <nav class="mb-6">
        <a href="/" class="text-sm text-gray-600 hover:text-sidebar transition-colors"><span aria-hidden="true">&larr;</span> Back to home</a>
      </nav>

      <article class="space-y-6">
        <h1 class="text-2xl sm:text-3xl font-serif font-light tracking-tight">Imprint</h1>

        <section class="space-y-3 text-gray-700 leading-relaxed text-sm">
          <h2 class="text-base font-semibold text-black">Information according to § 5 TMG</h2>
          <p>
            Marcin Skirzynski<br>
            Postfach [Number]<br>
            44137 Dortmund<br>
            Germany
          </p>
        </section>

        <section class="space-y-3 text-gray-700 leading-relaxed text-sm">
          <h2 class="text-base font-semibold text-black">Contact</h2>
          <p>E-Mail:
          <br/>marcin@daughterdriven.dev
          <br/>ola@daughterdriven.dev
          </p>
        </section>

        <section class="space-y-3 text-gray-700 leading-relaxed text-sm">
          <h2 class="text-base font-semibold text-black">Editorial Responsibility</h2>
          <p>
            Marcin Skirzynski<br>
            Ola Gasidlo-Brändel
          </p>
        </section>
      </article>
    </div>
  </div>

  <!-- Desktop Content -->
  <div class="hidden lg:block p-12">
    <div class="max-w-2xl">
      <nav class="mb-8">
        <a href="/" class="text-sm text-gray-600 hover:text-sidebar transition-colors"><span aria-hidden="true">&larr;</span> Back to home</a>
      </nav>

      <article class="space-y-8">
        <h1 class="text-4xl font-serif font-light tracking-tight">Imprint</h1>

        <section class="space-y-4 text-gray-700 leading-relaxed">
          <h2 class="text-lg font-semibold text-black">Information according to § 5 TMG</h2>
          <p>
            Marcin Skirzynski<br>
            Postfach [Number]<br>
            44137 Dortmund<br>
            Germany
          </p>
        </section>

        <section class="space-y-4 text-gray-700 leading-relaxed">
          <h2 class="text-lg font-semibold text-black">Contact</h2>
          <p>E-Mail:
          <br/>marcin@daughterdriven.dev
          <br/>ola@daughterdriven.dev
          </p>
        </section>

        <section class="space-y-4 text-gray-700 leading-relaxed">
          <h2 class="text-lg font-semibold text-black">Editorial Responsibility</h2>
          <p>
            Marcin Skirzynski<br>
            Ola Gasidlo-Brändel
          </p>
        </section>
      </article>
    </div>
  </div>
</BookLayout>
