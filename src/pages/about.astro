---
import BookLayout from '../layouts/BookLayout.astro';
---

<BookLayout
  title="About - daughterdriven.dev"
  description="About the book for engineers navigating parenthood."
>
  <div class="px-4 py-8 sm:p-8 lg:p-12">
    <div class="max-w-lg lg:max-w-2xl mx-auto lg:mx-0 lg:ml-8">
      <header class="mb-8 lg:mb-12">
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-serif font-light tracking-tight lg:text-sidebar">About</h1>
        <p class="mt-3 lg:mt-4 text-gray-700 lg:text-lg">About this book</p>
      </header>

      <div class="space-y-6 lg:space-y-8">
        <div>
          <h2 class="text-lg lg:text-xl font-semibold mb-2 lg:mb-3">What is this book about?</h2>
          <p class="text-gray-700 lg:text-lg lg:leading-relaxed">This book is for engineers who are navigating parenthood. It's about <mark>finding balance</mark> between your career ambitions and the beautiful chaos of raising children.</p>
        </div>
      </div>
    </div>
  </div>
</BookLayout>
