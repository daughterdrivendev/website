---
import '../styles/global.css';
import BookNav from '../components/BookNav.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  variant?: 'landing' | 'default';
  hideNewsletterForm?: boolean;
}

const {
  title,
  description,
  ogImage = 'https://daughterdriven.dev/og-image.jpeg',
  noindex = false,
  variant = 'default',
  hideNewsletterForm = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://daughterdriven.dev');
const currentPath = Astro.url.pathname;

const isLanding = variant === 'landing';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>

  {noindex && <meta name="robots" content="noindex">}

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon.svg">
</head>
<body class="min-h-screen">
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:text-sidebar focus:rounded"
  >
    Skip to content
  </a>

  <!-- Mobile Layout -->
  <div class="lg:hidden flex flex-col min-h-screen">
    <BookNav currentPath={currentPath} />
    <main id="main-content" class="flex-1 bg-book relative">
      <div class="absolute inset-0 bg-dots-bg opacity-60" style="background-image: radial-gradient(var(--color-dots) 0.55px, var(--color-dots-bg) 0.55px); background-size: 11px 11px;"></div>
      <div class="relative z-10">
        <slot />
      </div>
    </main>
  </div>

  <!-- Desktop Layout (Book Style) - Two full-height columns -->
  <div class="hidden lg:flex min-h-screen">
    {isLanding ? (
      <>
        <!-- Landing: 50/50 split -->
        <aside class="book-sidebar w-1/2 flex flex-col">
          <!-- Nav at top -->
          <nav class="book-nav py-3 px-6">
            <BookNav currentPath={currentPath} />
          </nav>

          <!-- Main sidebar content slot -->
          <div class="flex-1 flex flex-col items-center justify-center p-8">
            <slot name="sidebar" />
          </div>

          <!-- Footer Section -->
          <div class="p-8 pt-0">
            <div class="text-xs text-white/60 text-center">
              <a href="/imprint/" class="hover:text-white/80 transition-colors underline">Imprint</a>
            </div>
          </div>
        </aside>

        <!-- Right Content (Book Page) - Illustration -->
        <main id="main-content" class="book-content w-1/2 flex flex-col pt-3">
          <div class="flex-1 flex items-center justify-center overflow-y-auto">
            <slot name="main" />
          </div>
        </main>
      </>
    ) : (
      <>
        <!-- Blog/Default: 30/70 split -->
        <aside class="book-sidebar w-[30%] min-w-[280px] max-w-[380px] flex flex-col">
          <!-- Nav at top -->
          <nav class="book-nav py-3 px-6 flex justify-center">
            <BookNav currentPath={currentPath} navAlign="center" />
          </nav>

          <!-- Brand Section -->
          <div class="p-8 pt-24 space-y-6">
            <h1 class="text-3xl font-serif font-light tracking-tight">
              <a href="/" class="hover:text-primary-300 transition-colors">
                daughter<span class="italic">driven</span>.dev
              </a>
            </h1>
            <p class="text-white/80 text-sm leading-relaxed">
              A book for engineers navigating the beautiful chaos of parenthood.
            </p>
          </div>

          {!hideNewsletterForm && (
            <!-- Newsletter Form -->
            <div class="px-8 py-6">
              <p class="text-white/80 text-xs mb-3">Stay updated</p>
              <NewsletterForm variant="dark-inverse" layout="stacked" size="compact" shape="rounded" />
            </div>
          )}

          <!-- Spacer -->
          <div class="flex-1"></div>

          <!-- Imprint - bottom -->
          <div class="p-8 text-center text-xs text-white/60">
            <a href="/imprint/" class="hover:text-white/80 transition-colors underline">Imprint</a>
          </div>
        </aside>

        <!-- Right Content (Book Page) -->
        <main id="main-content" class="book-content flex-1 flex flex-col pt-3">
          <div class="flex-1 overflow-y-auto">
            <slot />
          </div>
        </main>
      </>
    )}
  </div>
</body>
</html>
